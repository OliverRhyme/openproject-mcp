# Base URL of your OpenProject instance (no trailing slash).
# e.g. https://community.openproject.org  or  https://op.your-company.com
OPENPROJECT_BASE_URL=https://community.openproject.org

# API key from your OpenProject account page → Access tokens → API.
# Used as the password in HTTP Basic Auth with literal username "apikey".
OPENPROJECT_API_KEY=

# Optional: default page size for list endpoints (max usually 1000).
# OPENPROJECT_PAGE_SIZE=25

# Optional: request timeout in milliseconds. Defaults to 30000.
# OPENPROJECT_TIMEOUT_MS=30000
